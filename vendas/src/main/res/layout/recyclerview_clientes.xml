<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:orientation="vertical">

    <!-- Nova Toolbar para Título e Navegação -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1976D2"
        android:elevation="4dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
        app:titleTextColor="#FFFFFF" />

    <!-- Cabeçalho Moderno com Barra de Busca e Chips -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="4dp"
        app:cardCornerRadius="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <androidx.appcompat.widget.SearchView
                android:id="@+id/searchViewClientes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_search_view"
                app:iconifiedByDefault="false"
                app:queryHint="Pesquisar cliente..."
                app:queryBackground="@android:color/transparent" />

            <!-- Filtros Rápidos (Chips) -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleLine="true"
                    app:chipSpacingHorizontal="8dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipTodos"
                        style="@style/Widget.MaterialComponents.Chip.Action"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Todos"
                        app:chipIcon="@android:drawable/ic_menu_agenda" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipRotas"
                        style="@style/Widget.MaterialComponents.Chip.Action"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rotas"
                        app:chipIcon="@android:drawable/ic_menu_directions" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipComPedidos"
                        style="@style/Widget.MaterialComponents.Chip.Action"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Com Pedidos"
                        app:chipIcon="@android:drawable/checkbox_on_background" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSeqVisita"
                        style="@style/Widget.MaterialComponents.Chip.Action"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Seq. Visita"
                        app:chipIcon="@android:drawable/ic_menu_sort_by_size" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipFiltros"
                        style="@style/Widget.MaterialComponents.Chip.Action"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Filtros"
                        app:chipIcon="@android:drawable/ic_menu_search" />

                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- LINHA DE STATUS DISCRETA (Inserida conforme solicitado) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        android:background="#E2E8F0"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/txtResumoFiltros"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Filtros: Rota: Central | Ord: Seq. Visita"
            android:textColor="#64748B"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/txtContagemClientes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total: 20"
            android:textColor="#475569"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Lista de Clientes -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_clientes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="16dp" />

</LinearLayout>